/target
**/*.rs.bk
Cargo.lock.bak

# Runtime server logs / watchdog crash dumps (stderr+stdout capture) - not source
/nfs-*.log
/nfs-*.out
vcpkg_installed/

# Build artifacts dropped here for local pickup (debs, flatpak bundle)
/dist/

# Playwright browser E2E: deps + run outputs (the specs/config ARE tracked)
/e2e/node_modules/
/e2e/test-results/
/e2e/playwright-report/
/e2e/.playwright/
